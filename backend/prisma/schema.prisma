datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
  engineType = "binary"
}

model User {
  id        String     @id @default(uuid())
  email     String     @unique
  password  String
  role      Role       @default(USER)
  documents Document[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model Document {
  id          String   @id @default(uuid())
  fileName    String
  fileHash    String
  storagePath String
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  createdAt   DateTime @default(now())

  @@index([fileHash])
  @@index([userId])
}

enum Role {
  USER
  ADMIN
}
